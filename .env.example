SMTP_SECURE=false
EMAIL_USER=
EMAIL_PASS=

OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_EXPIRY_MINUTES=15
BCRYPT_COST_PASSWORD=12
