NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb+srv://<user>:<pwd>@cluster0.mongodb.net/priceDrop?retryWrites=true&w=majority
# Add your frontend URL(s) (comma‑separated) for CORS
CLIENT_URL=http://localhost:3000
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=true

JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
